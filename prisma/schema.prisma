datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma/client"
}

model User {
  id               String           @id @default(uuid())
  email            String           @unique
  name             String?
  password         String
  role             String           @default("USER") // USER, ADMIN
  points           Int              @default(0)
  streak           Int              @default(0)
  lastLogin        DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  emissionRecords  EmissionRecord[]
  goals            Goal[]
  badges           UserBadge[]
  squads           SquadMember[]
  insights         AIInsight[]
  simulations      FootprintSimulation[]
  
  // Enterprise ESG
  organizationId   String?
  organization     Organization? @relation(fields: [organizationId], references: [id])
  
  // Web3
  wallet           EcoTokenWallet?
}

model EmissionRecord {
  id                   String   @id @default(uuid())
  userId               String
  date                 DateTime @default(now())
  
  // Transport inputs
  carDistance         Float    @default(0)
  bikeDistance        Float    @default(0)
  busDistance         Float    @default(0)
  trainDistance       Float    @default(0)
  flightDistance      Float    @default(0)
  transportEmissions  Float    @default(0)

  // Electricity inputs
  electricityKwh       Float    @default(0)
  electricityEmissions Float    @default(0)

  // Food inputs
  foodType             String   @default("mixed") // vegetarian, mixed, non-vegetarian
  foodEmissions        Float    @default(0)

  // Waste inputs
  wasteKg              Float    @default(0)
  wasteEmissions       Float    @default(0)

  // Combined totals
  totalEmissions       Float    @default(0)
  carbonScore          Float    @default(0)
  rating               String   @default("Moderate Impact") // Low, Moderate, High Impact

  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Goal {
  id              String   @id @default(uuid())
  userId          String
  title           String
  category        String   // transport, electricity, food, waste, overall
  targetReduction Float    @default(0) // target reduction %
  targetValue     Float    @default(0) // target emission level or savings
  currentValue    Float    @default(0)
  startDate       DateTime @default(now())
  endDate         DateTime
  completed       Boolean  @default(false)

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserBadge {
  id          String   @id @default(uuid())
  userId      String
  badgeName   String
  description String
  icon        String   // name of the lucide icon
  unlockedAt  DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EducationArticle {
  id          String   @id @default(uuid())
  title       String
  category    String   // Energy, Waste, Transport, Food
  summary     String
  content     String
  reads       Int      @default(0)
  carbonSaved Float    @default(0) // CO2 saved in kg by applying this guide
  createdAt   DateTime @default(now())
}

model Squad {
  id          String        @id @default(uuid())
  name        String        @unique
  description String?
  inviteCode  String        @unique
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  members     SquadMember[]
}

model SquadMember {
  id        String   @id @default(uuid())
  squadId   String
  userId    String
  role      String   @default("MEMBER") // ADMIN, MEMBER
  joinedAt  DateTime @default(now())
  
  squad     Squad    @relation(fields: [squadId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([squadId, userId])
}

model AIInsight {
  id        String   @id @default(uuid())
  userId    String
  content   String
  category  String   // transport, food, energy, general
  actionable Boolean @default(true)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FootprintSimulation {
  id              String   @id @default(uuid())
  userId          String
  scenarioName    String
  originalTotal   Float
  projectedTotal  Float
  savingsCo2      Float
  savingsCost     Float    @default(0)
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Organization {
  id          String   @id @default(uuid())
  name        String   @unique
  industry    String
  employeeCount Int    @default(0)
  createdAt   DateTime @default(now())

  employees   User[]
}

model GridAlert {
  id          String   @id @default(uuid())
  region      String
  status      String   // e.g., "High Carbon", "Clean Energy"
  message     String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model EcoTokenWallet {
  id          String   @id @default(uuid())
  userId      String   @unique
  balance     Float    @default(0) // $ECO tokens
  walletAddress String @unique
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
